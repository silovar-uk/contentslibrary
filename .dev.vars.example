# 任意のローカル上書き用。通常はwrangler.dev.jsoncだけで起動できます。
# .dev.varsへコピーした値はローカル開発だけで使用してください。
APP_ENV=development
DEV_AUTH_ENABLED=true
DEV_AUTH_EMAIL=owner@example.com
DEV_AUTH_SUB=dev-owner
OWNER_EMAIL=owner@example.com
ALLOW_OWNER_BOOTSTRAP=true
SEED_DEMO_DATA=true

# ローカルではAccessを使わないため、以下はダミーのままで構いません。
TEAM_DOMAIN=https://your-team.cloudflareaccess.com
POLICY_AUD=replace-with-access-audience-tag

# 本番値はGitHub Environment「production」のVariables / Secretsへ登録します。
# このファイルへ本番APIトークンを書かないでください。
# Worker管理画面からAccessセッション失効も行う場合のみ、
# CF_API_TOKEN / CF_ACCOUNT_IDをCloudflare Worker Secretとして別途登録します。
